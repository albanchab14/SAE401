{% extends "layout.njk" %}

{% block content %}
<div class="profile-page">

    <div class="profile-header-card" style="align-items: flex-start; display: flex; justify-content: space-between; gap: 40px; margin-bottom: 40px;">
        
        <div id="profile-view" style="display: flex; gap: 40px; flex: 1; align-items: center;">
            <div class="profile-avatar-wrapper">
                <img src="{{ user.avatar }}" alt="Avatar" class="profile-avatar">
            </div>
            <div class="profile-info">
                <h1 style="font-size: 32px; margin: 0 0 8px 0;">{{ user.name }}</h1>
                <span class="profile-date" style="color: #71717b; font-size: 14px;">Membre depuis {{ user.joinDate }}</span>
                <p class="profile-bio" style="color: #d4d4d8; margin: 15px 0; max-width: 500px; line-height: 1.6;">{{ user.bio }}</p>
                
                <div class="profile-actions" style="display: flex; gap: 12px;">
                    <button class="btn-outline" onclick="toggleEditProfile()">
                        <i data-lucide="settings" style="width: 16px; height: 16px;"></i> Modifier le profil
                    </button>
                    <button class="btn-outline btn-danger" onclick="deleteAccount()">
                        <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i> Supprimer le compte
                    </button>
                </div>
            </div>
        </div>

        <div id="profile-edit" class="hidden" style="display: flex; gap: 40px; flex: 1; align-items: flex-start;">
            <input type="file" id="avatar-upload" style="display: none;" accept="image/*">
            <div class="profile-avatar-wrapper edit-avatar" style="cursor: pointer;" onclick="document.getElementById('avatar-upload').click()">
                <img src="{{ user.avatar }}" alt="Avatar" id="avatar-preview" class="profile-avatar dim-avatar" style="object-fit: cover;">
                <div class="camera-icon">
                    <i data-lucide="camera" style="width: 24px; height: 24px; color: white;"></i>
                </div>
            </div>

            <div class="edit-form-fields" style="flex: 1; max-width: 400px; display: flex; flex-direction: column; gap: 12px;">
                <input type="text" id="edit-pseudo" value="{{ user.name }}" class="edit-input-modern" placeholder="Pseudo">
                
                <input type="email" id="edit-email" value="{{ user.email }}" class="edit-input-modern" placeholder="Adresse email" oninput="this.value = this.value.replace(/\s/g, '')">
                
                <div style="position: relative; width: 100%;">
                    <input type="password" id="edit-password" class="edit-input-modern" placeholder="Nouveau mot de passe" style="width: 100%; padding-right: 45px;">
                    <i data-lucide="eye" id="toggle-pwd-icon" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #71717b; width: 18px;" onclick="togglePassword()"></i>
                </div>
                
                <textarea id="edit-bio" class="edit-textarea-modern" placeholder="Votre biographie...">{{ user.bio }}</textarea>
                
                <div style="display: flex; gap: 12px; margin-top: 10px;">
                    <button class="btn-save-modern" onclick="saveProfile()">Sauvegarder</button>
                    <button class="btn-cancel-modern" onclick="toggleEditProfile()">Annuler</button>
                </div>
            </div>
        </div>

        <div class="profile-stats-modern">
            <div class="stat-item-modern" style="cursor: pointer;" onclick="switchTab('favorites', document.querySelectorAll('.tab-btn')[1])">
                <span class="stat-number-modern" style="background: linear-gradient(90deg, #d946ef, #e12afb); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ user.stats.favoris }}</span>
                <span class="stat-label-modern">FAVORIS</span>
            </div>
            <div style="width: 1px; height: 40px; background: #27272a;"></div>
            <div class="stat-item-modern" style="cursor: pointer;" onclick="switchTab('comments', document.querySelectorAll('.tab-btn')[0])">
                <span class="stat-number-modern" style="background: linear-gradient(90deg, #a855f7, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ user.stats.avis }}</span>
                <span class="stat-label-modern">AVIS</span>
            </div>
            <div style="width: 1px; height: 40px; background: #27272a;"></div>
            <div class="stat-item-modern">
                <span class="stat-number-modern" style="background: linear-gradient(90deg, #f43f5e, #ff2056); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ user.stats.suivis }}</span>
                <span class="stat-label-modern">SUIVIS</span>
            </div>
        </div>
    </div>

    <div class="profile-tabs" style="display: flex; gap: 30px; border-bottom: 1px solid #27272a; margin-bottom: 30px;">
        <button class="tab-btn active" onclick="switchTab('comments', this)">
            <i data-lucide="message-square" style="width: 18px; margin-right: 8px;"></i> Mes Avis
        </button>
        <button class="tab-btn" onclick="switchTab('favorites', this)">
            <i data-lucide="heart" style="width: 18px; margin-right: 8px;"></i> Mes Favoris
        </button>
        <button class="tab-btn" onclick="switchTab('stats', this)">
            <i data-lucide="bar-chart-2" style="width: 18px; margin-right: 8px;"></i> Mon Impact
        </button>
    </div>

    <div id="tab-comments" class="tab-content">
        <div class="comments-list">
            {% for comment in comments %}
            <div class="comment-card" style="background: #09090b; border: 1px solid #27272a; padding: 24px; border-radius: 16px; margin-bottom: 20px; display: flex; gap: 20px;">
                <a href="{{ comment.url }}">
                    <img src="{{ comment.image }}" style="width: 100px; height: 100px; border-radius: 12px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                </a>
                <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <a href="{{ comment.url }}" style="text-decoration: none;"><h3 style="margin: 0; color: white; font-size: 18px;">{{ comment.title }}</h3></a>
                            <span style="color: #a1a1aa; font-size: 13px;">{{ comment.artist }}</span>
                        </div>
                        <div style="color: #a1a1aa; display: flex; align-items: center; gap: 6px; font-size: 13px;">
                            <i data-lucide="thumbs-up" style="width: 14px;"></i> {{ comment.likes }}
                        </div>
                    </div>
                    <div style="display: flex; gap: 4px; margin: 12px 0;">
                        {% for i in range(0, 5) %}
                            <i data-lucide="star" style="width: 14px; height: 14px; fill: {% if i < comment.note %}#f0b100{% else %}none{% endif %}; color: #f0b100;"></i>
                        {% endfor %}
                    </div>
                    <p id="comment-content-{{ comment.id }}" style="color: #d4d4d8; font-size: 14px; line-height: 1.5; margin-bottom: 20px;">{{ comment.commentaire }}</p>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn-action-grey" onclick="openEditModal({{ comment.id }}, {{ comment.note }})"><i data-lucide="edit-2" style="width: 14px;"></i> Modifier</button>
                        <button class="btn-action-grey" onclick="deleteOwnComment({{ comment.id }})"><i data-lucide="trash-2" style="width: 14px;"></i> Supprimer</button>
                    </div>
                </div>
            </div>
            {% else %}
            <p style="color: #71717b;">Aucun avis pour le moment.</p>
            {% endfor %}
        </div>
    </div>

    <div id="tab-favorites" class="tab-content hidden">
        <div class="favorites-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 20px;">
            {% for fav in favorites %}
            <a href="{{ fav.url }}" class="fav-card" style="background: rgba(24,24,27,0.4); border: 1px solid #27272a; border-radius: 16px; padding: 12px; text-decoration: none; color: inherit; transition: transform 0.2s;">
                <img src="{{ fav.image }}" style="width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 12px; margin-bottom: 12px;">
                <h4 style="margin: 0; color: white; font-size: 15px;">{{ fav.title }}</h4>
                <p style="margin: 5px 0 0 0; color: #a1a1aa; font-size: 13px;">{{ fav.artist }}</p>
            </a>
            {% endfor %}
        </div>
    </div>

    <div id="tab-stats" class="tab-content hidden">
        <div class="impact-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
            <div class="impact-card">
                <div class="impact-icon" style="color: #d946ef;"><i data-lucide="star"></i></div>
                <p>Tu as donné <strong>{{ impact.albumsRated }} avis</strong> ce mois-ci.</p>
            </div>
            <div class="impact-card">
                <div class="impact-icon" style="color: #818cf8;"><i data-lucide="message-circle"></i></div>
                <p>Tu as commenté <strong>{{ impact.musicCommented }} titres</strong>.</p>
            </div>
        </div>
        
        <div class="did-you-know-banner" style="background: #1b0a2a; border: 1px solid rgba(217, 70, 239, 0.2); border-radius: 20px; padding: 30px; position: relative; overflow: hidden; margin-top: 40px;">
            <h3 style="color: white; font-size: 18px; margin-top: 0; margin-bottom: 12px; font-weight: 800;">Le savais-tu ?</h3>
            <p style="color: #d4d4d8; font-size: 15px; max-width: 85%; position: relative; z-index: 2;">Les membres qui commentent plus de 10 albums par mois ont 3x plus de chances d'apparaître dans les recommandations de la communauté. Continue comme ça !</p>
            <i data-lucide="music" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); width: 140px; height: 140px; color: rgba(255, 255, 255, 0.03); z-index: 1;"></i>
        </div>
    </div>
</div>

<div id="edit-modal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 9999;">
    <div style="background: #18181b; border: 1px solid #3f3f46; border-radius: 16px; width: 450px; padding: 24px;">
        <h3 style="color: white; margin-top: 0;">Modifier mon avis</h3>
        <div style="display: flex; gap: 10px; margin-bottom: 15px;" id="edit-star-rating">
            {% for i in [1,2,3,4,5] %}<div class="star-edit" data-val="{{i}}"><i data-lucide="star"></i></div>{% endfor %}
        </div>
        <textarea id="edit-comment-text" class="edit-textarea-modern"></textarea>
        <div style="display: flex; gap: 12px;">
            <button onclick="closeEditModal()" class="btn-cancel-modern">Annuler</button>
            <button onclick="submitEditComment()" class="btn-save-modern">Enregistrer</button>
        </div>
    </div>
</div>

<style>
    .edit-input-modern, .edit-textarea-modern { background: #000; border: 1px solid #27272a; color: white; padding: 12px 16px; border-radius: 12px; font-size: 14px; outline: none; width: 100%; }
    .btn-save-modern { background: #d946ef; color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: bold; cursor: pointer; }
    .btn-cancel-modern { background: #27272a; color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: bold; cursor: pointer; }
    .profile-stats-modern { display: flex; align-items: center; background: #0c0c0e; border: 1px solid #1a1a1c; border-radius: 16px; padding: 15px 30px; gap: 25px; }
    .stat-number-modern { font-size: 28px; font-weight: 900; }
    .stat-label-modern { font-size: 10px; color: #71717b; font-weight: 800; }
    .btn-action-grey { background: #18181b; border: 1px solid #27272a; color: #d4d4d8; padding: 6px 14px; border-radius: 10px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 6px; }
    .impact-card { background: rgba(24,24,27,0.4); border: 1px solid #27272a; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 15px; }
    .star-edit { color: #71717b; cursor: pointer; }
    .hidden { display: none !important; }
</style>

<script>
    if (typeof lucide !== 'undefined') lucide.createIcons();

    function switchTab(tabId, btnElement) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        document.getElementById('tab-' + tabId).classList.remove('hidden');
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        btnElement.classList.add('active');
    }

    function toggleEditProfile() {
        document.getElementById('profile-view').classList.toggle('hidden');
        document.getElementById('profile-edit').classList.toggle('hidden');
    }

    function togglePassword() {
        const input = document.getElementById('edit-password');
        const icon = document.getElementById('toggle-pwd-icon');
        input.type = input.type === "password" ? "text" : "password";
        icon.setAttribute('data-lucide', input.type === "password" ? 'eye' : 'eye-off');
        lucide.createIcons();
    }

    document.getElementById('avatar-upload').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => { document.getElementById('avatar-preview').src = event.target.result; };
            reader.readAsDataURL(file);
        }
    });

    async function saveProfile() {
        const formData = new FormData();
        formData.append('pseudo', document.getElementById('edit-pseudo').value);
        formData.append('email', document.getElementById('edit-email').value);
        formData.append('password', document.getElementById('edit-password').value);
        formData.append('bio', document.getElementById('edit-bio').value);
        const avatarFile = document.getElementById('avatar-upload').files[0];
        if(avatarFile) formData.append('avatar', avatarFile);

        const res = await fetch('/api/profil/edit', { method: 'POST', body: formData });
        if (res.ok) window.location.reload(); else alert("Erreur.");
    }

    async function deleteAccount() {
        if (confirm("Supprimer définitivement votre compte ?")) {
            const res = await fetch('/api/profil/delete', { method: 'DELETE' });
            if (res.ok) window.location.href = '/';
        }
    }

    async function deleteOwnComment(id) {
        if(confirm("Supprimer cet avis ?")) {
            const res = await fetch(`/api/comments/own/${id}`, { method: 'DELETE' });
            if(res.ok) window.location.reload();
        }
    }

    let editCommentId = null;
    let editSelectedNote = 0;
    function openEditModal(id, currentNote) {
        editCommentId = id;
        editSelectedNote = currentNote;
        document.getElementById('edit-comment-text').value = document.getElementById(`comment-content-${id}`).innerText;
        colorizeEditStars(currentNote);
        document.getElementById('edit-modal').style.display = 'flex';
    }
    function closeEditModal() { document.getElementById('edit-modal').style.display = 'none'; }

    const editStars = document.querySelectorAll('.star-edit');
    function colorizeEditStars(count) {
        editStars.forEach(s => {
            const val = parseInt(s.getAttribute('data-val'));
            const svg = s.querySelector('svg');
            if (val <= count) { svg.style.fill = '#f0b100'; svg.style.color = '#f0b100'; }
            else { svg.style.fill = 'none'; svg.style.color = '#71717b'; }
        });
    }
    editStars.forEach(s => {
        s.onclick = () => { editSelectedNote = parseInt(s.getAttribute('data-val')); colorizeEditStars(editSelectedNote); };
    });

    async function submitEditComment() {
        const text = document.getElementById('edit-comment-text').value;
        const res = await fetch(`/api/comments/own/${editCommentId}`, {
            method: 'PUT',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ note: editSelectedNote, commentaire: text })
        });
        if(res.ok) window.location.reload();
    }
</script>
{% endblock %}
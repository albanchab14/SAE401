{% extends "layout.njk" %}

{% block content %}
<div class="page-content">
  <div class="trackdetail-5">
    
    <div class="section-6" style="display: flex; gap: 40px; align-items: flex-end; margin-bottom: 48px;">
      <div class="container-7" style="width: 300px; height: 300px; border-radius: 24px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">
        <img src="{{ track.image }}" class="imagewithfallback-8" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300?text=No+Image'">
      </div>
      
      <div class="container-9">
        <p class="text-11" style="color: var(--primary); text-transform: uppercase; letter-spacing: 1.2px; font-size: 12px; margin-bottom: 8px;">Musique • {{ track.type }}</p>
        <h1 class="text-13" style="font-size: 72px; font-weight: 800; line-height: 1; margin-bottom: 12px;">{{ track.name }}</h1>
        <div class="container-14" style="display: flex; align-items: center; gap: 10px; color: var(--text-muted);">
          <a href="/artiste/{{ track.artist | urlencode }}" style="color: white; font-weight: bold; font-size: 20px; text-decoration: none;" onmouseover="this.style.color='#d946ef'" onmouseout="this.style.color='white'">
            {{ track.artist }}
          </a>
          <span>•</span>
          <span>{{ track.album }}</span>
          <span>•</span>
          <span>{{ track.duration }}</span>
        </div>
        
        <div class="container-21" style="display: flex; gap: 12px; margin-top: 24px;">
          <button class="btn-details-white"><i data-lucide="heart"></i> Favori</button>
          <button class="btn-details-dark"><i data-lucide="share-2"></i> Partager</button>
        </div>
      </div>
    </div>

    <div class="main-layout-details" style="display: flex; gap: 48px;">
      
      <div class="left-col" style="flex: 2;">
        
        <div class="section-36" style="display: flex; gap: 16px; margin-bottom: 40px;">
          <div class="stat-box" style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); padding: 24px; border-radius: 16px; flex: 1; text-align: center;">
            <p style="font-size: 10px; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase;">Écoutes</p>
            <p style="font-size: 24px; color: var(--primary); font-weight: bold;">{{ track.playcount }}</p>
          </div>
          <div class="stat-box" style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); padding: 24px; border-radius: 16px; flex: 1; text-align: center;">
            <p style="font-size: 10px; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase;">Auditeurs</p>
            <p style="font-size: 24px; color: white; font-weight: bold;">{{ track.listeners }}</p>
          </div>
        </div>

        <h2 style="margin-bottom: 16px;">À propos du titre</h2>
        <div class="wiki-content" style="color: var(--text-muted); line-height: 1.6; margin-bottom: 48px;">
          {{ track.wiki | safe }}
        </div>

        <div class="distribution-container" style="background: #0c0c0e; border: 1px solid #1a1a1c; border-radius: 20px; padding: 30px; margin-bottom: 40px;">
          <p style="font-size: 14px; color: #a1a1aa; font-weight: 800; letter-spacing: 1px; margin-bottom: 30px; text-transform: uppercase;">Distribution des notes</p>

          {% set stats = [
            {stars: 5, width: 75, count: 3},
            {stars: 4, width: 30, count: 1},
            {stars: 3, width: 2, count: 0},
            {stars: 2, width: 2, count: 0},
            {stars: 1, width: 2, count: 0}
          ] %}

          {% for row in stats %}
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px; background: rgba(255,255,255,0.02); padding: 10px 20px; border-radius: 12px;">
            <div style="display: flex; gap: 4px; width: 85px;">
              {% for i in range(5) %}
                <i data-lucide="star" style="width: 14px; height: 14px; fill: {% if i < row.stars %}#f0b100{% else %}none{% endif %}; stroke: {% if i < row.stars %}#f0b100{% else %}#3f3f46{% endif %};"></i>
              {% endfor %}
            </div>
            <div style="flex: 1; height: 6px; background: #1a1a1c; border-radius: 10px; overflow: hidden;">
              <div style="width: {{ row.width }}%; height: 100%; background: #f0b100; border-radius: 10px; box-shadow: 0 0 10px rgba(240, 177, 0, 0.3);"></div>
            </div>
            <span style="color: #a1a1aa; font-weight: bold; width: 20px; text-align: right;">{{ row.count }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      <div class="right-col" style="flex: 1;">
        <div class="sidebar-info" style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); border-radius: 24px; padding: 24px;">
          <h3 style="margin-bottom: 24px;">Détails techniques</h3>
          
          <div style="margin-bottom: 16px; display: flex; justify-content: space-between;">
            <span style="color: var(--text-muted);"><i data-lucide="calendar" style="width:14px;"></i> Année</span>
            <span>{{ track.year }}</span>
          </div>
          <div style="margin-bottom: 16px; display: flex; justify-content: space-between;">
            <span style="color: var(--text-muted);"><i data-lucide="disc" style="width:14px;"></i> Album</span>
            <span style="text-align: right;">{{ track.album }}</span>
          </div>
          <div style="margin-bottom: 24px; display: flex; justify-content: space-between;">
            <span style="color: var(--text-muted);"><i data-lucide="clock" style="width:14px;"></i> Durée</span>
            <span>{{ track.duration }}</span>
          </div>

          <p style="font-size: 10px; color: #52525c; margin-bottom: 16px; text-transform: uppercase; font-weight: bold;">Mots-clés</p>
          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px;">
            {% if track.tags.length > 0 %}
              {% for tag in track.tags %}
              <span style="background: #27272a; border: 1px solid #3f3f47; color: var(--text-muted); padding: 4px 12px; border-radius: 10px; font-size: 10px; font-weight: bold;">{{ tag.name }}</span>
              {% endfor %}
            {% else %}
              <span style="color: #52525c; font-size: 11px;">Indisponible</span>
            {% endif %}
          </div>

          <h3>Crédits</h3>
          <p style="color: var(--text-muted); font-size: 10px; margin-top: 16px; text-transform: uppercase;">Compositeurs</p>
          <p style="font-size: 14px;">{{ track.artist }}, Max Martin</p>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .btn-details-white { background: white; color: black; border: none; padding: 12px 28px; border-radius: 14px; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.2s; }
  .btn-details-white:hover { transform: scale(1.05); background: #f4f4f5; }
  .btn-details-dark { background: #18181b; color: white; border: 1px solid #27272a; padding: 12px 28px; border-radius: 14px; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.2s; }
  .btn-details-dark:hover { background: #27272a; }
</style>
{% endblock %}
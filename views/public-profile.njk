{% extends "layout.njk" %}

{% block content %}
<div class="profile-page" style="margin-top: -15px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
        <a href="javascript:history.back()" class="back-button" style="display: inline-flex; align-items: center; gap: 8px; color: #a1a1aa; text-decoration: none; font-weight: bold; transition: 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='#a1a1aa'">
            <i data-lucide="chevron-left"></i> Retour
        </a>

        <div class="user-search-container" style="position: relative; width: 100%; max-width: 280px;">
            <div style="position: relative;">
                <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #71717b; width: 16px;"></i>
                <input type="text" id="user-search-input" placeholder="Rechercher un membre..." style="width: 100%; background: #18181b; border: 1px solid #27272a; color: white; padding: 10px 10px 10px 36px; border-radius: 12px; font-size: 14px; outline: none; box-sizing: border-box; transition: border-color 0.2s;" onfocus="this.style.borderColor='#d946ef'" onblur="this.style.borderColor='#27272a'">
            </div>
            <div id="user-search-results" style="position: absolute; top: 100%; left: 0; right: 0; background: #18181b; border: 1px solid #27272a; border-radius: 12px; margin-top: 8px; z-index: 50; display: none; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.8);"></div>
        </div>
    </div>

    <div class="profile-header-card" style="display: flex; justify-content: space-between; align-items: center; gap: 40px; margin-bottom: 30px;">
        
        <div style="display: flex; gap: 40px; flex: 1; align-items: center;">
            <div class="profile-avatar-wrapper">
                <img src="{{ publicUser.avatar }}" alt="Avatar" class="profile-avatar">
            </div>
            <div class="profile-info">
                <h1 style="font-size: 32px; margin: 0 0 8px 0;">{{ publicUser.name }}</h1>
                <span class="profile-date" style="color: #71717b; font-size: 14px;">Membre depuis {{ publicUser.joinDate }}</span>
                <p class="profile-bio" style="color: #d4d4d8; margin: 15px 0; max-width: 500px; line-height: 1.6;">{{ publicUser.bio }}</p>
            </div>
        </div>

        <div class="public-profile-right" style="display: flex; flex-direction: column; align-items: flex-end; gap: 20px;">
            <div class="profile-stats-modern" style="display: flex; align-items: center; background: #0c0c0e; border: 1px solid #1a1a1c; border-radius: 16px; padding: 15px 30px;">
                <div class="stat-item-modern" style="display: flex; flex-direction: column; align-items: center; cursor: pointer;" onclick="switchTab('favorites', document.querySelectorAll('.tab-btn')[0])">
                    <span class="stat-number-modern" style="font-size: 28px; font-weight: 900; background: linear-gradient(90deg, #d946ef, #e12afb); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ publicUser.stats.favoris | default(0) }}</span>
                    <span class="stat-label-modern" style="font-size: 10px; color: #71717b; font-weight: 800; letter-spacing: 1px;">FAVORIS</span>
                </div>
                <div style="width: 1px; height: 30px; background: #27272a; margin: 0 20px;"></div>
                <div class="stat-item-modern" style="display: flex; flex-direction: column; align-items: center; cursor: pointer;" onclick="switchTab('comments', document.querySelectorAll('.tab-btn')[1])">
                    <span class="stat-number-modern" style="font-size: 28px; font-weight: 900; background: linear-gradient(90deg, #a855f7, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ publicUser.stats.avis | default(0) }}</span>
                    <span class="stat-label-modern" style="font-size: 10px; color: #71717b; font-weight: 800; letter-spacing: 1px;">AVIS</span>
                </div>
                <div style="width: 1px; height: 30px; background: #27272a; margin: 0 20px;"></div>
                
                <div class="stat-item-modern" style="display: flex; flex-direction: column; align-items: center; cursor: pointer;" onclick="openFollowersModal('{{ publicUser.id }}')">
                    <span id="followers-count" class="stat-number-modern" style="font-size: 28px; font-weight: 900; background: linear-gradient(90deg, #f43f5e, #ff2056); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ publicUser.stats.suivis | default(0) }}</span>
                    <span class="stat-label-modern" style="font-size: 10px; color: #71717b; font-weight: 800; letter-spacing: 1px;">SUIVIS</span>
                </div>
            </div>
            
            {% if user and user.id != publicUser.id %}
            <button id="follow-btn" class="btn-subscribe" onclick="toggleFollow('{{ publicUser.id }}')" 
                style="background: {% if isFollowing %}linear-gradient(90deg, #ef4444 0%, #b91c1c 100%){% else %}linear-gradient(90deg, #d946ef 0%, #8b5cf6 100%){% endif %}; color: white; border: none; padding: 12px 28px; border-radius: 12px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: 0.3s; box-shadow: {% if isFollowing %}0 4px 15px rgba(239, 68, 68, 0.4){% else %}0 4px 15px rgba(217, 70, 239, 0.4){% endif %}; width: 100%;">
                <span id="follow-text">{% if isFollowing %}Se désabonner{% else %}S'abonner{% endif %}</span> <i data-lucide="arrow-right" style="width: 18px;"></i>
            </button>
            {% endif %}
        </div>
    </div>

    <div class="profile-tabs" style="display: flex; gap: 30px; border-bottom: 1px solid #27272a; margin-bottom: 16px;">
        <button class="tab-btn active" onclick="switchTab('favorites', this)">
            <i data-lucide="heart" style="width: 18px; margin-right: 8px;"></i> Ses Favoris
        </button>
        <button class="tab-btn" onclick="switchTab('comments', this)">
            <i data-lucide="message-square" style="width: 18px; margin-right: 8px;"></i> Ses Avis
        </button>
    </div>

    <div id="tab-favorites" class="tab-content" style="margin: 0 !important; padding: 0 !important;">
        <div class="favorites-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 20px; margin: 0; padding: 0;">
            {% for fav in favorites %}
            <a href="{{ fav.url }}" class="fav-card" style="background: rgba(24,24,27,0.4); border: 1px solid #27272a; border-radius: 16px; padding: 12px; text-decoration: none; color: inherit; transition: transform 0.2s;" onmouseover="this.style.background='rgba(39,39,42,0.6)'; this.style.transform='translateY(-5px)'" onmouseout="this.style.background='rgba(24,24,27,0.4)'; this.style.transform='translateY(0)'">
                <img src="{{ fav.image }}" alt="{{ fav.title }}" style="width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 12px; margin-bottom: 6px;">
                <h4 style="margin: 0; color: white; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ fav.title }}</h4>
                <p style="margin: 2px 0 0 0; color: #a1a1aa; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ fav.artist }}</p>
            </a>
            {% else %}
            <p style="color: #71717b; grid-column: 1 / -1; text-align: center; padding: 20px 0;">Aucun favori pour le moment.</p>
            {% endfor %}
        </div>
    </div>

    <div id="tab-comments" class="tab-content hidden" style="margin: 0 !important; padding: 0 !important;">
        <div class="comments-list" style="margin: 0; padding: 0;">
            {% for comment in comments %}
            <div class="comment-card" style="background: #09090b; border: 1px solid #27272a; padding: 24px; border-radius: 16px; margin-bottom: 20px; display: flex; gap: 20px;">
                <a href="{{ comment.url }}">
                    <img src="{{ comment.image }}" style="width: 100px; height: 100px; border-radius: 12px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                </a>
                <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <a href="{{ comment.url }}" style="text-decoration: none; display: flex; align-items: center; gap: 8px; color: white;" onmouseover="this.style.color='#d946ef'" onmouseout="this.style.color='white'">
                                <h3 style="margin: 0; font-size: 18px; transition: color 0.2s;">{{ comment.title }}</h3>
                                <i data-lucide="external-link" style="width: 14px; height: 14px;"></i>
                            </a>
                            <span style="color: #a1a1aa; font-size: 13px;">{{ comment.artist }}</span>
                        </div>
                        <div style="color: #a1a1aa; display: flex; align-items: center; gap: 6px; font-size: 13px;">
                            <i data-lucide="thumbs-up" style="width: 14px;"></i> {{ comment.likes }}
                        </div>
                    </div>
                    <div style="display: flex; gap: 4px; margin: 12px 0;">
                        {% for i in range(0, 5) %}
                            <i data-lucide="star" style="width: 14px; height: 14px; fill: {% if i < comment.note %}#f0b100{% else %}none{% endif %}; color: #f0b100;"></i>
                        {% endfor %}
                    </div>
                    <p style="color: #d4d4d8; font-size: 14px; line-height: 1.5; margin-bottom: 0;">{{ comment.commentaire }}</p>
                </div>
            </div>
            {% else %}
            <p style="color: #71717b;">Aucun avis pour le moment.</p>
            {% endfor %}
        </div>
    </div>

</div>

<div id="followers-modal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); display: none; justify-content: center; align-items: center; z-index: 1000; backdrop-filter: blur(5px);">
    <div style="background: #18181b; border: 1px solid #27272a; border-radius: 24px; width: 100%; max-width: 450px; padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 style="display: flex; align-items: center; gap: 12px; color: white; margin: 0; font-size: 22px;">
                <i data-lucide="users" style="color: #d946ef;"></i> Abonnés
            </h2>
            <i data-lucide="x" style="cursor: pointer; color: #71717b;" onclick="document.getElementById('followers-modal').style.display='none'"></i>
        </div>
        <div id="followers-list" style="max-height: 350px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px;"></div>
    </div>
</div>

<style>
    .hidden { display: none !important; }
</style>

<script>
    if (typeof lucide !== 'undefined') lucide.createIcons();

    // NOUVEAU SCRIPT POUR SWITCHER LES ONGLETS
    function switchTab(tabId, btnElement) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        document.getElementById('tab-' + tabId).classList.remove('hidden');
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        btnElement.classList.add('active');
    }

    // SCRIPT DE RECHERCHE DE MEMBRES
    const searchInput = document.getElementById('user-search-input');
    const searchResults = document.getElementById('user-search-results');

    if (searchInput) {
        searchInput.addEventListener('input', async (e) => {
            const q = e.target.value.trim();
            if (q.length < 2) {
                searchResults.style.display = 'none';
                return;
            }
            try {
                const res = await fetch(`/api/search-users?q=${encodeURIComponent(q)}`);
                const users = await res.json();
                
                if (users.length > 0) {
                    searchResults.innerHTML = users.map(u => `
                        <a href="/user/${u.pseudo}" style="display: flex; align-items: center; gap: 12px; padding: 12px; text-decoration: none; color: white; border-bottom: 1px solid #27272a; transition: background 0.2s;" onmouseover="this.style.background='#27272a'" onmouseout="this.style.background='transparent'">
                            <img src="${u.avatar || 'https://ui-avatars.com/api/?name='+u.pseudo+'&background=27272a&color=fff'}" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;">
                            <span style="font-weight: bold; font-size: 14px;">${u.pseudo}</span>
                        </a>
                    `).join('');
                    searchResults.style.display = 'block';
                } else {
                    searchResults.innerHTML = '<div style="padding: 15px; color: #71717b; font-size: 13px; text-align: center;">Aucun membre trouvé</div>';
                    searchResults.style.display = 'block';
                }
            } catch(err) {}
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.style.display = 'none';
            }
        });
    }

    async function toggleFollow(userId) {
        const res = await fetch(`/api/user/${userId}/follow`, { method: 'POST' });
        
        if (res.status === 401) {
            window.location.href = '/login';
            return;
        }

        const data = await res.json();
        const btn = document.getElementById('follow-btn');
        const text = document.getElementById('follow-text');
        
        // ✨ ON CIBLE LE COMPTEUR
        const countElement = document.getElementById('followers-count');
        let currentCount = parseInt(countElement.innerText) || 0;
        
        if (data.isFollowing) {
            // Design Désabonnement
            btn.style.background = "linear-gradient(90deg, #ef4444 0%, #b91c1c 100%)";
            btn.style.boxShadow = "0 4px 15px rgba(239, 68, 68, 0.4)";
            text.innerText = "Se désabonner";
            
            // On ajoute +1 instantanément au compteur !
            countElement.innerText = currentCount + 1;
        } else {
            // Design Abonnement
            btn.style.background = "linear-gradient(90deg, #d946ef 0%, #8b5cf6 100%)";
            btn.style.boxShadow = "0 4px 15px rgba(217, 70, 239, 0.4)";
            text.innerText = "S'abonner";
            
            // On enlève -1 instantanément
            countElement.innerText = currentCount - 1 > 0 ? currentCount - 1 : 0;
        }
        
    }

    async function openFollowersModal(userId) {
        const modal = document.getElementById('followers-modal');
        const list = document.getElementById('followers-list');
        modal.style.display = 'flex';
        list.innerHTML = '<p style="color: #71717b; text-align: center;">Chargement...</p>';
        try {
            const res = await fetch(`/api/user/${userId}/followers`);
            const followers = await res.json();
            if (followers.length === 0) {
                list.innerHTML = '<p style="color: #71717b; text-align: center; padding: 20px;">Aucun abonné.</p>';
            } else {
                list.innerHTML = followers.map(f => `
                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border-bottom: 1px solid #27272a;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <img src="${f.avatar || 'https://ui-avatars.com/api/?name='+f.pseudo}" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                            <span style="color: white; font-weight: bold;">${f.pseudo}</span>
                        </div>
                        <a href="/user/${f.pseudo}" style="background: #27272a; color: white; padding: 6px 12px; border-radius: 8px; font-size: 11px; text-decoration: none; font-weight: 800;">VOIR</a>
                    </div>
                `).join('');
            }
        } catch (e) { list.innerHTML = '<p style="color: #ef4444; text-align: center;">Erreur lors du chargement.</p>'; }
    }
</script>
{% endblock %}
{% extends "layout.njk" %}

{% block content %}
<div class="login-container">

  <div class="login-box">
    <div class="login-header">
      <div class="auth-icon-glow">
        <i data-lucide="music" style="color: white; width: 32px; height: 32px;"></i>
      </div>
      <h2>Créer un compte</h2>
      <p>Rejoignez la communauté et partagez vos pépites.</p>
    </div>

    {% if error %}
      <div style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 12px; border: 1px solid rgba(239, 68, 68, 0.5); border-radius: 8px; margin-bottom: 20px; font-size: 14px; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
        <i data-lucide="alert-circle" style="width: 18px; height: 18px;"></i>
        {{ error }}
      </div>
    {% endif %}

    <form class="login-form" action="/register" method="POST">

      <div class="input-group">
        <div class="input-wrapper">
          <i data-lucide="user" class="input-icon"></i>
          <input type="text" name="username" placeholder="Nom d'utilisateur" required>
        </div>
      </div>

      <div class="input-group">
        <div class="input-wrapper">
          <i data-lucide="mail" class="input-icon"></i>
          <input type="email" name="email" placeholder="Adresse email" required>
        </div>
      </div>

      <div class="input-group">
        <div class="input-wrapper">
          <i data-lucide="lock" class="input-icon"></i>
          <input type="password" name="password" placeholder="Mot de passe" required>
          <i data-lucide="eye" class="input-icon-right" style="cursor: pointer;"></i>
        </div>
      </div>

      <button type="submit" class="btn-submit-purple">
        S'inscrire <i data-lucide="arrow-right" style="width: 18px; height: 18px;"></i>
      </button>

    </form>

    <a href="/login" class="register-link" style="display: block; text-align: center; margin-top: 20px; color: #a1a1aa; text-decoration: none;">Déjà un compte ? Se connecter</a>
  </div>

</div>
{% endblock %}
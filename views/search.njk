{% extends "layout.njk" %}

{% block content %}
<div class="explorer-container">

  <aside class="filters-panel">
    <div class="filter-header">
      <i data-lucide="sliders-horizontal"></i>
      <h2>Filtres</h2>
    </div>

    <div class="filter-group">
      <h3 class="filter-title"><i data-lucide="music-2" style="width: 16px;"></i> Genres</h3>
      <div class="filter-pills">
        {% for tag in ['Tous', 'Pop', 'Hip-Hop', 'Electronic', 'Jazz', 'Rock'] %}
          <a href="/search?q={{ query or '' }}&type={{ currentType or 'Album' }}&years={{ currentYears or 'Toutes' }}&tag={{ tag }}" 
             class="filter-pill {% if currentTag == tag or (tag == 'Tous' and not currentTag) %}active{% endif %}">
            {{ tag }}
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group">
      <h3 class="filter-title"><i data-lucide="calendar" style="width: 16px;"></i> Années</h3>
      <div class="filter-pills">
        {% for y in ['Toutes', '2024-2026', '2020-2023', '2010-2019', '2000s'] %}
          <a href="/search?q={{ query or '' }}&type={{ currentType or 'Album' }}&tag={{ currentTag or 'Tous' }}&years={{ y }}" 
             class="filter-pill {% if currentYears == y or (y == 'Toutes' and not currentYears) %}active{% endif %}">
            {{ y }}
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group">
      <h3 class="filter-title"><i data-lucide="disc" style="width: 16px;"></i> Type</h3>
      <div class="filter-pills">
        {% for t in ['Album', 'Artiste', 'Musique', 'Playlist'] %}
          <a href="/search?q={{ query or '' }}&tag={{ currentTag or 'Tous' }}&years={{ currentYears or 'Toutes' }}&type={{ t }}" 
             class="filter-pill {% if currentType == t or (not currentType and t == 'Album') %}active{% endif %}">
            {{ t }}
          </a>
        {% endfor %}
      </div>
    </div>
  </aside>

  <div class="results-panel">
    <div class="results-header">
      <h2>Résultats pour "{{ query or 'Tout explorer' }}"</h2>
      <span class="results-count">{{ results.length }} résultats</span>
    </div>

    <div class="grid">
      {% if results.length > 0 %}
        {% for item in results %}
          {% if item.type == "Artiste" %}
              {% set targetUrl = "/artiste/" + (item.title | urlencode) %}
          {% elseif item.type == "Musique" %}
              {% set targetUrl = "/details/" + (item.title | urlencode) %}
          {% else %}
              {% set targetUrl = "/album/" + (item.artist | urlencode) + "/" + (item.title | urlencode) %}
          {% endif %}
          
          <a href="{{ targetUrl }}" class="card">
            <div class="card-img-wrapper" style="{% if item.type == 'Artiste' %}border-radius: 50%; aspect-ratio: 1/1; overflow: hidden;{% endif %}">
              <img src="{{ item.image }}" alt="{{ item.title }}" 
                   onerror="this.src='https://ui-avatars.com/api/?name={{ item.title | urlencode }}&background=random&size=300'">
              
              {% if item.rating and item.rating > 0 %}
              <div class="rating-badge">
                <i data-lucide="star" style="width: 12px; fill: #eab308; color: #eab308;"></i>
                {{ item.rating }}
              </div>
              {% endif %}

            </div>
            <h3>{{ item.title }}</h3>
            <p>{{ item.artist }}</p>
            <div class="card-meta">
              <span class="meta-tag">{{ item.type }}</span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div style="grid-column: 1/-1; text-align: center; padding: 100px 0; opacity: 0.5;">
          <i data-lucide="search-x" style="width: 48px; margin-bottom: 20px;"></i>
          <p>Aucun résultat pour cette sélection.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
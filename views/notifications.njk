{% extends "layout.njk" %}

{% block content %}
<div class="notifications-page">
    
    <div class="notifications-header">
        <h1>Notifications</h1>
        {% if notifications.length > 0 %}
        <button class="mark-read-btn">Tout supprimer</button>
        {% endif %}
    </div>

    <div class="notifications-list">
        
        {% if notifications.length > 0 %}
            
            {% for notif in notifications %}
            <div class="notif-card" id="notif-{{ notif.id }}">
                <div class="notif-icon-wrapper" style="background-color: {{ notif.bgColor }};">
                    <i data-lucide="{{ notif.icon }}" style="color: {{ notif.color }}; width: 20px;"></i>
                </div>
                <div class="notif-content">
                    <p class="notif-text">
                        <a href="/profil/{{ notif.user }}" class="notif-user notif-link">{{ notif.user }}</a> 
                        
                        {{ notif.action | safe }}
                    </p>
                    <span class="notif-time">{{ notif.time }}</span>
                </div>
                <button class="delete-notif-btn" data-id="{{ notif.id }}" title="Supprimer">
                    <i data-lucide="trash-2"></i>
                </button>
            </div>
            {% endfor %}

        {% else %}
            
            <div class="empty-state">
                <i data-lucide="bell-off" class="empty-icon"></i>
                <h2>Aucune notification</h2>
                <p>Vous êtes à jour ! Vos notifications apparaîtront ici quand vous en recevrez.</p>
            </div>

        {% endif %}
        
    </div>
</div>

<style>
    .notifications-page {
        padding: 40px;
        max-width: 900px;
        margin: 0 auto; /* Centre la page */
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

    .notifications-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .notifications-header h1 {
        color: #f4f4f5;
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin: 0;
    }

    .mark-read-btn {
        background: transparent;
        border: none;
        color: #71717b;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        cursor: pointer;
        transition: color 0.2s;
    }

    .mark-read-btn:hover {
        color: #e12afb; /* Violet BPM */
    }

    .notifications-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* CARTE DE NOTIFICATION */
    .notif-card {
        background-color: rgba(24, 24, 27, 0.4);
        border: 1px solid rgba(39, 39, 42, 1);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: background 0.2s ease;
    }

    .notif-card:hover {
        background-color: rgba(39, 39, 42, 0.6);
    }

    .notif-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
    }

    .notif-content {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .notif-text {
        color: #e4e4e7;
        font-size: 15px;
        margin: 0;
    }

    .notif-user {
        color: #ffffff;
        font-weight: 700;
    }

    .notif-time {
        color: #71717b;
        font-size: 13px;
    }

    /* DESIGN QUAND C'EST VIDE */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background-color: rgba(24, 24, 27, 0.2);
        border: 1px dashed rgba(63, 63, 71, 0.5);
        border-radius: 16px;
    }

    .empty-icon {
        width: 48px;
        height: 48px;
        color: #3f3f46;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        color: #f4f4f5;
        font-size: 20px;
        margin-bottom: 10px;
    }

    .empty-state p {
        color: #a1a1aa;
        font-size: 15px;
    }

    .delete-notif-btn {
        margin-left: auto; /* Pousse le bouton tout à droite */
        background: transparent;
        border: none;
        color: #71717b;
        cursor: pointer;
        padding: 8px;
        border-radius: 8px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .delete-notif-btn:hover {
        background-color: rgba(239, 68, 68, 0.1); /* Fond rouge léger */
        color: #ef4444; /* Poubelle rouge */
    }

    /* DESIGN DES LIENS CLIQUABLES */
    .notif-link {
        text-decoration: none;
        color: inherit; /* Garde la couleur d'origine du texte */
        transition: color 0.2s ease;
    }

    .notif-link:hover {
        color: #e12afb; /* Devient Violet BPM au survol */
        text-decoration: underline;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. GESTION DE LA POUBELLE
    const deleteBtns = document.querySelectorAll('.delete-notif-btn');
    
    deleteBtns.forEach(btn => {
        btn.addEventListener('click', async function() {
            const notifId = this.getAttribute('data-id');
            const card = document.getElementById(`notif-${notifId}`);
            
            // Appel à la route Node.js en tâche de fond
            const response = await fetch(`/notifications/delete/${notifId}`, { method: 'POST' });
            const data = await response.json();
            
            if (data.success) {
                // Animation de disparition
                card.style.opacity = '0';
                card.style.transform = 'translateX(20px)';
                card.style.transition = 'all 0.3s ease';
                setTimeout(() => card.remove(), 300); // Supprime le HTML après l'animation
            }
        });
    });

    // 2. GESTION DU "TOUT MARQUER COMME LU"
    const markAllBtn = document.querySelector('.mark-read-btn');
    if (markAllBtn) {
        markAllBtn.addEventListener('click', async () => {
            const response = await fetch('/notifications/read-all', { method: 'POST' });
            const data = await response.json();
            
            if (data.success) {
                const notifList = document.querySelector('.notifications-list');
                // On vide la liste avec une animation
                notifList.style.opacity = '0';
                notifList.style.transition = 'opacity 0.3s ease';
                
                setTimeout(() => {
                    // On affiche le design "Vide" (ton empty-state)
                    notifList.innerHTML = `
                        <div class="empty-state">
                            <i data-lucide="bell-off" class="empty-icon"></i>
                            <h2>Aucune notification</h2>
                            <p>Vous êtes à jour ! Vos notifications apparaîtront ici quand vous en recevrez.</p>
                        </div>
                    `;
                    notifList.style.opacity = '1';
                    markAllBtn.style.display = 'none'; // Cache le bouton "Tout marquer"
                    lucide.createIcons(); // Recharge l'icône bell-off
                }, 300);
            }
        });
    }

    lucide.createIcons();
});
</script>
{% endblock %}
{% extends "layout.njk" %}

{% block content %}
<div class="admin-dashboard">
    
    <div class="admin-header">
        <div>
            <h1>Dashboard Admin</h1>
            <p>Gestion globale de la plateforme BPM.</p>
        </div>
        <div class="maintenance-toggle">
            <span class="dot" style="background: {% if isMaintenance %}#fe9a00{% else %}#00bc7d{% endif %}; box-shadow: 0 0 8px {% if isMaintenance %}#fe9a00{% else %}#00bc7d{% endif %};"></span> 
            Mode Maintenance
            <label class="switch">
                <input type="checkbox" onchange="toggleMaintenance(this)" {% if isMaintenance %}checked{% endif %}>
                <span class="slider"></span>
            </label>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(43, 127, 255, 0.1); color: #2b7fff;"><i data-lucide="users"></i></div>
            <p class="stat-title">Utilisateurs</p><h3 class="stat-value">{{ stats.users }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(225, 42, 251, 0.1); color: #e12afb;"><i data-lucide="message-square"></i></div>
            <p class="stat-title">Commentaires</p><h3 class="stat-value">{{ stats.comments }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(254, 154, 0, 0.1); color: #fe9a00;"><i data-lucide="alert-triangle"></i></div>
            <p class="stat-title">Signalements</p><h3 class="stat-value">{{ stats.reports }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(0, 188, 125, 0.1); color: #00bc7d;"><i data-lucide="star"></i></div>
            <p class="stat-title">Artistes à la une</p><h3 class="stat-value">{{ stats.artists }}</h3>
        </div>
    </div>

    <div class="admin-section">
        <div class="section-top" style="display: flex; justify-content: space-between; align-items: center;">
            <div class="section-title"><i data-lucide="users" style="color: #2b7fff;"></i> Gestion des utilisateurs</div>
            <div class="section-search" style="position: relative;">
                <i data-lucide="search" style="width: 16px; color:#71717b;"></i>
                <input type="text" id="user-search-input" placeholder="Chercher pseudo ou email..." autocomplete="off" onkeyup="filterUsers()">
            </div>
        </div>
        <div style="overflow-x: auto;">
            <table class="admin-table">
                <thead>
                    <tr><th>ID</th><th>UTILISATEUR</th><th>EMAIL</th><th>RÔLE</th><th>STATUT</th><th style="text-align: right;">ACTIONS</th></tr>
                </thead>
                <tbody>
                    {% for u in users %}
                    <tr id="user-row-{{ u.id }}">
                        <td style="color: #71717b;">#{{ u.id }}</td>
                        <td>
                            <div class="user-cell">
                                <img src="{{ u.avatar if u.avatar else 'https://ui-avatars.com/api/?name=' + u.pseudo + '&background=27272a&color=fff' }}">
                                <a href="/user/{{ u.pseudo | urlencode }}" style="color: #f4f4f5; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#d946ef'" onmouseout="this.style.color='#f4f4f5'">
                                    <strong>{{ u.pseudo }}</strong>
                                </a>
                            </div>
                        </td>
                        <td style="color: #a1a1aa;">{{ u.email }}</td>
                        <td>
                            <select class="role-select {% if u.role == 'admin' %}role-admin{% else %}role-user{% endif %}" onchange="changeRole({{ u.id }}, this.value, this)" title="Changer le rôle">
                                <option value="utilisateur" {% if u.role == 'utilisateur' %}selected{% endif %}>UTILISATEUR</option>
                                <option value="admin" {% if u.role == 'admin' %}selected{% endif %}>ADMIN</option>
                            </select>
                        </td>
                        <td>
                            <span class="status" id="status-{{ u.id }}">
                                <span class="status-dot" style="background-color: {% if u.is_banned %}#ff2056{% else %}#00bc7d{% endif %};"></span> 
                                <span style="color: #d4d4d8;">{% if u.is_banned %}Banni{% else %}Actif{% endif %}</span>
                            </span>
                        </td>
                        <td style="text-align: right; display: flex; gap: 10px; align-items: center; justify-content: flex-end;">
                            <button class="action-btn action-edit" title="Modifier l'utilisateur" onclick="openEditUserModal({{ u.id }}, '{{ u.pseudo | escape }}', '{{ u.email | escape }}')" style="margin:0;">
                                <i data-lucide="edit-2"></i>
                            </button>
                            
                            <button class="action-btn" title="{% if u.is_banned %}Débannir l'utilisateur{% else %}Bannir l'utilisateur{% endif %}" onclick="toggleBan({{ u.id }}, this)" style="margin:0;">
                                <i data-lucide="{% if u.is_banned %}check-circle{% else %}ban{% endif %}"></i>
                            </button>
                            <button class="action-btn action-delete" title="Supprimer définitivement" onclick="deleteUser({{ u.id }})" style="margin:0;">
                                <i data-lucide="trash-2"></i>
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="admin-section" style="margin-top: 40px;">
        <div class="section-top">
            <div class="section-title"><i data-lucide="alert-triangle" style="color: #fe9a00;"></i> Commentaires signalés</div>
        </div>
        <div style="overflow-x: auto;">
            <table class="admin-table">
                <thead>
                    <tr><th>ID</th><th>UTILISATEUR</th><th>COMMENTAIRE</th><th>CIBLE</th><th>MOTIF</th><th>SGNL.</th><th style="text-align: right;">ACTIONS</th></tr>
                </thead>
                <tbody>
                    {% for r in reports %}
                    <tr id="report-row-{{ r.comment_id }}">
                        <td style="color: #71717b;">#{{ r.comment_id }}</td>
                        <td style="color: #f4f4f5;">
                            <a href="/user/{{ r.pseudo | urlencode }}" style="color: #f4f4f5; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#d946ef'" onmouseout="this.style.color='#f4f4f5'">
                                <strong>{{ r.pseudo }}</strong>
                            </a>
                        </td>
                        <td style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="{{ r.comment }}">
                            {{ r.comment }}
                        </td>
                        <td>
                            <a href="{{ r.url }}" style="color: #d946ef; text-decoration: none; font-weight: bold; display: inline-flex; align-items: center; gap: 5px;">
                                {{ r.music_item_id }} <i data-lucide="external-link" style="width: 14px;"></i>
                            </a>
                        </td>                 
                        <td style="color: #a1a1aa; font-size: 13px;">
                            {{ r.reason }}
                        </td>
                        <td>
                            <span style="background: rgba(254, 154, 0, 0.1); color: #fe9a00; padding: 2px 6px; border-radius: 4px; font-size: 12px; font-weight: bold;">x{{ r.count }}</span>
                        </td>
                        <td style="text-align: right; display: flex; gap: 10px; align-items: center; justify-content: flex-end;">
                            <button class="action-btn action-check" title="Ignorer le signalement" onclick="ignoreReport({{ r.comment_id }})" style="margin:0;">
                                <i data-lucide="check"></i>
                            </button>
                            <button class="action-btn action-delete" title="Supprimer le commentaire" onclick="deleteComment({{ r.comment_id }})" style="margin:0;">
                                <i data-lucide="trash-2"></i>
                            </button>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="7" style="padding: 30px; text-align: center; color: #71717b;">Aucun signalement.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="admin-section" style="margin-top: 40px;">
        <div class="section-top">
            <div class="section-title"><i data-lucide="star" style="color: #00bc7d;"></i> Artistes à la une</div>
            <div class="section-search" style="position: relative;">
                <i data-lucide="search" style="width: 16px; color:#71717b;"></i>
                <input type="text" id="artist-search-input" placeholder="Ajouter un artiste..." autocomplete="off">
                <div id="artist-suggestions" class="dropdown-suggestions"></div>
            </div>
        </div>

        <div style="overflow-x: auto;">
            <table class="admin-table">
                <thead>
                    <tr><th>POSITION</th><th>ARTISTE</th><th>AUDITEURS</th><th style="text-align: right;">ACTIONS</th></tr>
                </thead>
                <tbody>
                    {% for a in featuredArtists %}
                    <tr {% if loop.index0 == 0 %}style="background: rgba(225,42,251,0.05);"{% endif %}>
                        <td>
                            <input type="number" class="position-input" value="{{ a.position }}" min="1" max="6" 
                                   oninput="if(this.value > 6) this.value = 6; if(this.value < 1 && this.value !== '') this.value = 1;" 
                                   onchange="swapArtistPosition({{ a.db_id }}, this.value)" title="Changer l'ordre">
                        </td>
                        <td>
                            <div class="artist-cell">
                                <img src="{{ a.image }}" alt="{{ a.name }}">
                                <div class="artist-info">
                                    <strong style="color: #f4f4f5; font-size: 15px;">{{ a.name }}</strong>
                                    {% if loop.index0 == 0 %}
                                    <span style="color: #e12afb; font-size: 10px; font-weight: bold; text-transform: uppercase;">Section à la une</span>
                                    {% endif %}
                                </div>
                            </div>
                            
                            {% if loop.index0 == 0 %}
                            <div class="artist-desc-box">
                                <div style="width: 150px;">
                                    <strong style="color: #f4f4f5; display:block; font-size: 14px;">Description</strong>
                                    <span style="color: #e12afb; font-size: 10px; font-weight: bold; text-transform: uppercase;">Affichée sur l'accueil</span>
                                </div>
                                <textarea class="desc-text" onchange="updateDesc({{ a.db_id }}, this.value)" placeholder="Écrivez l'accroche ici...">{{ a.desc }}</textarea>
                            </div>
                            {% endif %}
                        </td>
                        <td style="color: #a1a1aa;">{{ a.listeners }}</td>
                        <td style="text-align: right;">
                            <button class="action-btn action-delete" title="Supprimer (Remplace par un aléatoire)" onclick="randomizeArtist({{ a.db_id }}, '{{ a.name }}')"><i data-lucide="trash-2"></i></button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="replace-modal" class="modal-overlay" style="display: none;">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-icon"><i data-lucide="refresh-cw"></i></div>
            <div>
                <h3>Remplacer un artiste</h3>
                <p class="modal-subtitle">Quota maximum atteint (6/6)</p>
            </div>
        </div>
        
        <p class="modal-text">Sélectionnez l'artiste que vous souhaitez remplacer par <strong id="new-artist-name-display" style="color: #d946ef; font-size: 1.1em;"></strong> :</p>
        
        <div class="custom-select-wrapper">
            <select id="replace-select" class="custom-select">
                {% for a in featuredArtists %}
                    <option value="{{ a.db_id }}">Position {{ a.position }} - {{ a.name }}</option>
                {% endfor %}
            </select>
            <i data-lucide="chevron-down" class="select-icon"></i>
        </div>
        
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()">Annuler</button>
            <button class="btn-confirm" onclick="confirmReplace()">
                <i data-lucide="check" style="width: 16px; height: 16px; margin-right: 6px;"></i> Confirmer
            </button>
        </div>
    </div>
</div>

<div id="edit-user-modal" class="modal-overlay" style="display: none;">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;"><i data-lucide="edit-2"></i></div>
            <div>
                <h3>Modifier l'utilisateur</h3>
                <p class="modal-subtitle" id="edit-user-id-display"></p>
            </div>
        </div>
        
        <div style="display: flex; flex-direction: column; gap: 15px; margin: 20px 0;">
            <input type="hidden" id="edit-user-id">
            <div>
                <label style="color: #a1a1aa; font-size: 12px; font-weight: bold; margin-bottom: 5px; display: block; text-transform: uppercase;">Pseudo</label>
                <input type="text" id="edit-user-pseudo" class="custom-select" style="cursor: text;">
            </div>
            <div>
                <label style="color: #a1a1aa; font-size: 12px; font-weight: bold; margin-bottom: 5px; display: block; text-transform: uppercase;">Adresse Email</label>
                <input type="email" id="edit-user-email" class="custom-select" style="cursor: text;">
            </div>
            <div>
                <label style="color: #a1a1aa; font-size: 12px; font-weight: bold; margin-bottom: 5px; display: block; text-transform: uppercase;">Nouveau mot de passe</label>
                <div style="position: relative;">
                    <input type="password" id="edit-user-password" class="custom-select" style="cursor: text; padding-right: 40px;" placeholder="Laisser vide pour ne pas le changer">
                    <i data-lucide="eye" id="toggle-edit-pwd" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #71717b; width: 18px;" onclick="toggleEditPassword()"></i>
                </div>
            </div>
        </div>
        
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeEditUserModal()">Annuler</button>
            <button class="btn-confirm" onclick="submitEditUser()" style="background: linear-gradient(135deg, #3b82f6, #2563eb); box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);">
                <i data-lucide="save" style="width: 16px; height: 16px; margin-right: 6px;"></i> Enregistrer
            </button>
        </div>
    </div>
</div>

<script>
    if (typeof lucide !== 'undefined') lucide.createIcons();

    // SCRIPT POUR LE BOUTON OEIL (MOT DE PASSE ADMIN)
    function toggleEditPassword() {
        const pwdInput = document.getElementById('edit-user-password');
        const icon = document.getElementById('toggle-edit-pwd');
        if (pwdInput.type === 'password') {
            pwdInput.type = 'text';
            icon.setAttribute('data-lucide', 'eye-off');
        } else {
            pwdInput.type = 'password';
            icon.setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }

    function openEditUserModal(id, pseudo, email) {
        document.getElementById('edit-user-id').value = id;
        document.getElementById('edit-user-id-display').innerText = "ID Utilisateur : #" + id;
        document.getElementById('edit-user-pseudo').value = pseudo;
        document.getElementById('edit-user-email').value = email;
        
        // On remet le champ mot de passe à zéro et caché par défaut
        const pwdInput = document.getElementById('edit-user-password');
        pwdInput.value = ""; 
        pwdInput.type = 'password';
        document.getElementById('toggle-edit-pwd').setAttribute('data-lucide', 'eye');
        lucide.createIcons();

        document.getElementById('edit-user-modal').style.display = 'flex';
    }

    function closeEditUserModal() {
        document.getElementById('edit-user-modal').style.display = 'none';
    }

    async function submitEditUser() {
        const id = document.getElementById('edit-user-id').value;
        const pseudo = document.getElementById('edit-user-pseudo').value;
        const email = document.getElementById('edit-user-email').value;
        const password = document.getElementById('edit-user-password').value;

        try {
            const res = await fetch(`/api/admin/users/${id}/edit`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pseudo, email, password })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.error || "Erreur lors de la modification.");
            }
        } catch(e) {
            alert("Erreur serveur.");
        }
    }

    async function toggleMaintenance(checkbox) {
        await fetch('/api/admin/maintenance', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ active: checkbox.checked })
        });
        window.location.reload();
    }

    async function changeRole(id, newRole, selectElement) {
        if (!confirm(`Changer le rôle de cet utilisateur en ${newRole.toUpperCase()} ?`)) {
            window.location.reload(); return;
        }
        const res = await fetch(`/api/admin/users/${id}/role`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ role: newRole })
        });
        if (res.ok) {
            if (newRole === 'admin') { selectElement.classList.remove('role-user'); selectElement.classList.add('role-admin'); } 
            else { selectElement.classList.remove('role-admin'); selectElement.classList.add('role-user'); }
        }
    }

    async function toggleBan(id, btnElement) {
        const isBanning = btnElement.innerHTML.includes('ban');
        if (!confirm(isBanning ? "Bannir cet utilisateur ?" : "Débannir et réactiver ce compte ?")) return;
        
        const res = await fetch(`/api/admin/users/${id}/ban`, { method: 'POST' });
        const data = await res.json();

        if (data.is_banned == 1) {
            document.getElementById(`status-${id}`).innerHTML = '<span class="status-dot" style="background-color: #ff2056;"></span> <span style="color: #d4d4d8;">Banni</span>';
            btnElement.innerHTML = '<i data-lucide="check-circle"></i>';
            btnElement.title = "Débannir l'utilisateur";
        } else {
            document.getElementById(`status-${id}`).innerHTML = '<span class="status-dot" style="background-color: #00bc7d;"></span> <span style="color: #d4d4d8;">Actif</span>';
            btnElement.innerHTML = '<i data-lucide="ban"></i>';
            btnElement.title = "Bannir l'utilisateur";
        }
        lucide.createIcons();
    }
    
    async function deleteUser(id) {
        if (!confirm("Supprimer DÉFINITIVEMENT cet utilisateur de la base de données ?")) return;
        if ((await fetch(`/api/admin/users/${id}`, { method: 'DELETE' })).ok) document.getElementById(`user-row-${id}`).remove();
    }

    async function ignoreReport(id) {
        if(confirm("Ignorer ce signalement ? (Le commentaire sera conservé sur le site)")) {
            const res = await fetch(`/api/admin/reports/${id}/ignore`, { method: 'POST' });
            if(res.ok) document.getElementById(`report-row-${id}`).remove();
            else alert("Erreur serveur.");
        }
    }
    
    async function deleteComment(id) {
        if (!confirm("Attention : Supprimer ce commentaire de la base de données pour infraction ?")) return;
        const res = await fetch(`/api/admin/comments/${id}`, { method: 'DELETE' });
        if(res.ok) document.getElementById(`report-row-${id}`).remove();
        else alert("Erreur serveur.");
    }

    async function updateDesc(id, text) {
        await fetch('/api/admin/artists/description', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id, desc: text }) });
    }

    async function swapArtistPosition(dbId, newPos) {
        const position = parseInt(newPos);
        if (isNaN(position) || position < 1 || position > 6) {
            alert("❌ Erreur : La position doit obligatoirement être comprise entre 1 et 6 !");
            window.location.reload(); 
            return;
        }
        await fetch('/api/admin/artists/reorder', { 
            method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: dbId, newPosition: position }) 
        });
        window.location.reload();
    }

    async function randomizeArtist(id, name) {
        if (!confirm(`Supprimer ${name} et ajouter un artiste aléatoire du Top Mondial à sa place ?`)) return;
        await fetch(`/api/admin/artists/${id}/randomize`, { method: 'POST' });
        window.location.reload();
    }

    const searchInput = document.getElementById('artist-search-input');
    const suggBox = document.getElementById('artist-suggestions');
    let artistToAdd = "";

    searchInput.addEventListener('input', async (e) => {
        const val = e.target.value;
        if (val.length < 2) { suggBox.style.display = 'none'; return; }
        const res = await fetch(`/api/suggest?q=${encodeURIComponent(val)}`);
        const data = await res.json();
        suggBox.innerHTML = '';
        data.filter(item => item.type === "artiste").forEach(item => {
            const div = document.createElement('div');
            div.className = "sugg-item";
            div.innerHTML = `<strong>${item.title}</strong>`;
            div.onclick = () => showReplaceModal(item.title);
            suggBox.appendChild(div);
        });
        suggBox.style.display = 'block';
    });

    function showReplaceModal(name) {
        suggBox.style.display = 'none';
        searchInput.value = '';
        artistToAdd = name;
        document.getElementById('new-artist-name-display').innerText = name;
        document.getElementById('replace-modal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('replace-modal').style.display = 'none'; }

    async function confirmReplace() {
        const select = document.getElementById('replace-select');
        const res = await fetch('/api/admin/artists/replace', {
            method: 'POST', headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ oldArtistId: select.value, newArtistName: artistToAdd })
        });
        const data = await res.json();
        if (data.error) alert("Erreur : " + data.error); else window.location.reload();
    }

    // SCRIPT POUR FILTRER LES UTILISATEURS EN DIRECT
    function filterUsers() {
        const input = document.getElementById('user-search-input').value.toLowerCase();
        // On cible toutes les lignes du tableau des utilisateurs
        const rows = document.querySelectorAll('tr[id^="user-row-"]');
        
        rows.forEach(row => {
            // Le pseudo est dans la 2ème colonne (index 1), l'email dans la 3ème (index 2)
            const pseudo = row.cells[1].innerText.toLowerCase();
            const email = row.cells[2].innerText.toLowerCase();
            
            // Si la recherche correspond au pseudo ou à l'email, on affiche, sinon on cache
            if (pseudo.includes(input) || email.includes(input)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>
{% endblock %}
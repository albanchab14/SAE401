{% extends "layout.njk" %}

{% block content %}
<div class="admin-dashboard">
    
    <div class="admin-header">
        <div>
            <h1>Dashboard Admin</h1>
            <p>Gestion globale de la plateforme BPM.</p>
        </div>
        <div class="maintenance-toggle">
            <span class="dot" style="background: {% if isMaintenance %}#fe9a00{% else %}#00bc7d{% endif %}; box-shadow: 0 0 8px {% if isMaintenance %}#fe9a00{% else %}#00bc7d{% endif %};"></span> 
            Mode Maintenance
            <label class="switch">
                <input type="checkbox" onchange="toggleMaintenance(this)" {% if isMaintenance %}checked{% endif %}>
                <span class="slider"></span>
            </label>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(43, 127, 255, 0.1); color: #2b7fff;"><i data-lucide="users"></i></div>
            <p class="stat-title">Utilisateurs</p><h3 class="stat-value">{{ stats.users }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(225, 42, 251, 0.1); color: #e12afb;"><i data-lucide="message-square"></i></div>
            <p class="stat-title">Commentaires</p><h3 class="stat-value">{{ stats.comments }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(254, 154, 0, 0.1); color: #fe9a00;"><i data-lucide="alert-triangle"></i></div>
            <p class="stat-title">Signalements</p><h3 class="stat-value">{{ stats.reports }}</h3>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(0, 188, 125, 0.1); color: #00bc7d;"><i data-lucide="star"></i></div>
            <p class="stat-title">Artistes à la une</p><h3 class="stat-value">{{ stats.artists }}</h3>
        </div>
    </div>

    <div class="admin-section">
        <div class="section-top">
            <div class="section-title"><i data-lucide="users" style="color: #2b7fff;"></i> Gestion des utilisateurs</div>
        </div>
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>UTILISATEUR</th><th>EMAIL</th><th>RÔLE</th><th>STATUT</th><th style="text-align: right;">ACTIONS</th></tr>
            </thead>
            <tbody>
                {% for u in users %}
                <tr id="user-row-{{ u.id }}">
                    <td style="color: #71717b;">#{{ u.id }}</td>
                    <td>
                        <div class="user-cell">
                            <img src="{{ u.avatar if u.avatar else 'https://ui-avatars.com/api/?name=' + u.pseudo + '&background=27272a&color=fff' }}">
                            <strong style="color: #f4f4f5;">{{ u.pseudo }}</strong>
                        </div>
                    </td>
                    <td style="color: #a1a1aa;">{{ u.email }}</td>
                    <td><span class="badge {% if u.role == 'admin' %}badge-admin{% else %}badge-user{% endif %}">{{ u.role | upper }}</span></td>
                    <td>
                        <span class="status" id="status-{{ u.id }}">
                            <span class="status-dot" style="background-color: {% if u.is_banned %}#ff2056{% else %}#00bc7d{% endif %};"></span> 
                            <span style="color: #d4d4d8;">{% if u.is_banned %}Banni{% else %}Actif{% endif %}</span>
                        </span>
                    </td>
                    <td style="text-align: right;">
                        <button class="action-btn" title="{% if u.is_banned %}Débannir l'utilisateur{% else %}Bannir l'utilisateur{% endif %}" onclick="toggleBan({{ u.id }}, this)">
                            <i data-lucide="{% if u.is_banned %}check-circle{% else %}ban{% endif %}"></i>
                        </button>
                        <button class="action-btn action-delete" title="Supprimer définitivement" onclick="deleteUser({{ u.id }})"><i data-lucide="trash-2"></i></button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="admin-section" style="margin-top: 40px;">
        <div class="section-top">
            <div class="section-title"><i data-lucide="alert-triangle" style="color: #fe9a00;"></i> Commentaires signalés</div>
        </div>
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>UTILISATEUR</th><th>COMMENTAIRE</th><th>RAISON</th><th>SIGNALEMENTS</th><th style="text-align: right;">ACTIONS</th></tr>
            </thead>
            <tbody>
                {% for r in reports %}
                <tr id="report-row-{{ r.comment_id }}">
                    <td style="color: #71717b;">#{{ r.comment_id }}</td>
                    <td style="color: #f4f4f5;"><strong>{{ r.pseudo }}</strong></td>
                    <td style="color: #a1a1aa; max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="{{ r.comment }}">{{ r.comment }}</td>
                    <td style="color: #d4d4d8;">{{ r.reason }}</td>
                    <td><span class="badge badge-warning">{{ r.count }}</span></td>
                    <td style="text-align: right;">
                        <button class="action-btn" title="Ignorer le signalement" onclick="ignoreReport({{ r.comment_id }})"><i data-lucide="check"></i></button>
                        <button class="action-btn action-delete" title="Supprimer le commentaire" onclick="deleteComment({{ r.comment_id }})"><i data-lucide="trash-2"></i></button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="admin-section" style="margin-top: 40px;">
        <div class="section-top">
            <div class="section-title"><i data-lucide="star" style="color: #00bc7d;"></i> Artistes à la une</div>
            <div class="section-search" style="position: relative;">
                <i data-lucide="search" style="width: 16px; color:#71717b;"></i>
                <input type="text" id="artist-search-input" placeholder="Ajouter un artiste..." autocomplete="off">
                <div id="artist-suggestions" class="dropdown-suggestions"></div>
            </div>
        </div>

        <table class="admin-table">
            <thead>
                <tr><th>POSITION</th><th>ARTISTE</th><th>AUDITEURS</th><th style="text-align: right;">ACTIONS</th></tr>
            </thead>
            <tbody>
                {% for a in featuredArtists %}
                <tr {% if loop.index0 == 0 %}style="background: rgba(225,42,251,0.05);"{% endif %}>
                    <td>
                                <input type="number" class="position-input" value="{{ a.position }}" min="1" max="6" 
                oninput="if(this.value > 6) this.value = 6; if(this.value < 1 && this.value !== '') this.value = 1;" 
                onchange="swapArtistPosition({{ a.db_id }}, this.value)" title="Changer l'ordre">
                    </td>
                    <td>
                        <div class="artist-cell">
                            <img src="{{ a.image }}" alt="{{ a.name }}">
                            <div class="artist-info">
                                <strong style="color: #f4f4f5; font-size: 15px;">{{ a.name }}</strong>
                                {% if loop.index0 == 0 %}
                                <span style="color: #e12afb; font-size: 10px; font-weight: bold; text-transform: uppercase;">Section à la une</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        {% if loop.index0 == 0 %}
                        <div class="artist-desc-box">
                            <div style="width: 150px;">
                                <strong style="color: #f4f4f5; display:block; font-size: 14px;">Description</strong>
                                <span style="color: #e12afb; font-size: 10px; font-weight: bold; text-transform: uppercase;">Affichée sur l'accueil</span>
                            </div>
                            <textarea class="desc-text" onchange="updateDesc({{ a.db_id }}, this.value)" placeholder="Écrivez l'accroche ici...">{{ a.desc }}</textarea>
                        </div>
                        {% endif %}
                    </td>
                    <td style="color: #a1a1aa;">{{ a.listeners }}</td>
                    <td style="text-align: right;">
                        <button class="action-btn action-delete" title="Supprimer (Remplace par un aléatoire)" onclick="randomizeArtist({{ a.db_id }}, '{{ a.name }}')"><i data-lucide="trash-2"></i></button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div id="replace-modal" class="modal-overlay" style="display: none;">
    <div class="modal-box">
        <h3>Remplacer un artiste</h3>
        <p>Il y a déjà 6 artistes à la une. Quel artiste voulez-vous remplacer par <strong id="new-artist-name-display" style="color: #d946ef;"></strong> ?</p>
        <select id="replace-select" class="custom-select">
            {% for a in featuredArtists %}
                <option value="{{ a.db_id }}">{{ a.name }}</option>
            {% endfor %}
        </select>
        <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
            <button class="btn-cancel" onclick="closeModal()">Annuler</button>
            <button class="btn-confirm" onclick="confirmReplace()">Remplacer</button>
        </div>
    </div>
</div>

<script>
    if (typeof lucide !== 'undefined') lucide.createIcons();

    // MAINTENANCE
    async function toggleMaintenance(checkbox) {
        await fetch('/api/admin/maintenance', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ active: checkbox.checked })
        });
        window.location.reload();
    }

    // UTILISATEURS
    async function toggleBan(id, btnElement) {
        const isBanning = btnElement.innerHTML.includes('ban');
        if (!confirm(isBanning ? "Bannir cet utilisateur ?" : "Débannir et réactiver ce compte ?")) return;
        
        const res = await fetch(`/api/admin/users/${id}/ban`, { method: 'POST' });
        const data = await res.json();

        if (data.is_banned == 1) {
            document.getElementById(`status-${id}`).innerHTML = '<span class="status-dot" style="background-color: #ff2056;"></span> <span style="color: #d4d4d8;">Banni</span>';
            btnElement.innerHTML = '<i data-lucide="check-circle"></i>';
            btnElement.title = "Débannir l'utilisateur";
        } else {
            document.getElementById(`status-${id}`).innerHTML = '<span class="status-dot" style="background-color: #00bc7d;"></span> <span style="color: #d4d4d8;">Actif</span>';
            btnElement.innerHTML = '<i data-lucide="ban"></i>';
            btnElement.title = "Bannir l'utilisateur";
        }
        lucide.createIcons();
    }
    
    async function deleteUser(id) {
        if (!confirm("Supprimer DÉFINITIVEMENT cet utilisateur de la base de données ?")) return;
        if ((await fetch(`/api/admin/users/${id}`, { method: 'DELETE' })).ok) document.getElementById(`user-row-${id}`).remove();
    }

    // COMMENTAIRES
    async function ignoreReport(id) {
        if ((await fetch(`/api/admin/reports/${id}/ignore`, { method: 'POST' })).ok) document.getElementById(`report-row-${id}`).remove();
    }
    async function deleteComment(id) {
        if (!confirm("Supprimer ce commentaire pour toujours ?")) return;
        if ((await fetch(`/api/admin/comments/${id}`, { method: 'DELETE' })).ok) document.getElementById(`report-row-${id}`).remove();
    }

    // ARTISTES
    async function updateDesc(id, text) {
        await fetch('/api/admin/artists/description', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id, desc: text }) });
    }

async function swapArtistPosition(dbId, newPos) {
        const position = parseInt(newPos);
        // Sécurité stricte : On bloque si ce n'est pas entre 1 et 6
        if (isNaN(position) || position < 1 || position > 6) {
            alert("❌ Erreur : La position doit obligatoirement être comprise entre 1 et 6 !");
            window.location.reload(); // Annule la modification visuelle
            return;
        }

        await fetch('/api/admin/artists/reorder', { 
            method: 'POST', 
            headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ id: dbId, newPosition: position }) 
        });
        window.location.reload(); // Recharge pour afficher le nouvel ordre
    }

    async function randomizeArtist(id, name) {
        if (!confirm(`Supprimer ${name} et ajouter un artiste aléatoire du Top Mondial à sa place ?`)) return;
        await fetch(`/api/admin/artists/${id}/randomize`, { method: 'POST' });
        window.location.reload();
    }

    // RECHERCHE ARTISTE ANTI-DOUBLON
    const searchInput = document.getElementById('artist-search-input');
    const suggBox = document.getElementById('artist-suggestions');
    let artistToAdd = "";

    searchInput.addEventListener('input', async (e) => {
        const val = e.target.value;
        if (val.length < 2) { suggBox.style.display = 'none'; return; }
        const res = await fetch(`/api/suggest?q=${encodeURIComponent(val)}`);
        const data = await res.json();
        suggBox.innerHTML = '';
        data.filter(item => item.type === "artiste").forEach(item => {
            const div = document.createElement('div');
            div.className = "sugg-item";
            div.innerHTML = `<strong>${item.title}</strong>`;
            div.onclick = () => showReplaceModal(item.title);
            suggBox.appendChild(div);
        });
        suggBox.style.display = 'block';
    });

    function showReplaceModal(name) {
        suggBox.style.display = 'none';
        searchInput.value = '';
        artistToAdd = name;
        document.getElementById('new-artist-name-display').innerText = name;
        document.getElementById('replace-modal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('replace-modal').style.display = 'none'; }

    async function confirmReplace() {
        const select = document.getElementById('replace-select');
        const res = await fetch('/api/admin/artists/replace', {
            method: 'POST', headers: {'Content-Type': 'application/json'}, 
            body: JSON.stringify({ oldArtistId: select.value, newArtistName: artistToAdd })
        });
        const data = await res.json();
        if (data.error) {
            alert("Erreur : " + data.error); // Gère l'anti-doublon "Cet artiste y est déjà"
        } else {
            window.location.reload();
        }
    }
</script>

<style>
    /* CSS Identique à la version précédente (très propre) */
    .admin-dashboard { padding: 40px; max-width: 1200px; margin: 0 auto; color: white; font-family: 'Inter', sans-serif; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .admin-header h1 { font-size: 30px; font-weight: bold; margin: 0; }
    .admin-header p { color: #71717b; margin: 5px 0 0 0; }
    .maintenance-toggle { background: rgba(24,24,27,0.5); border: 1px solid #27272a; padding: 10px 20px; border-radius: 14px; display: flex; align-items: center; gap: 12px; color: #d4d4d8; font-weight: bold; }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: rgba(24,24,27,0.4); border: 1px solid #27272a; border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 12px; }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; justify-content: center; align-items: center; }
    .stat-title { color: #71717b; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; margin: 0; font-weight: bold; }
    .stat-value { font-size: 32px; margin: 0; font-weight: bold; }
    .admin-section { background: rgba(24,24,27,0.4); border: 1px solid #27272a; border-radius: 20px; padding-top: 24px; }
    .section-top { display: flex; justify-content: space-between; align-items: center; padding: 0 24px 20px 24px; border-bottom: 1px solid #27272a; }
    .section-title { font-size: 20px; font-weight: bold; display: flex; align-items: center; gap: 12px; }
    .section-search { display: flex; align-items: center; background: #09090b; border: 1px solid #3f3f46; padding: 8px 16px; border-radius: 12px; gap: 10px; }
    .section-search input { background: transparent; border: none; color: white; outline: none; }
    .dropdown-suggestions { position: absolute; top: 110%; left: 0; width: 100%; background: #18181b; border: 1px solid #3f3f46; border-radius: 12px; display: none; overflow: hidden; z-index: 100; box-shadow: 0 10px 25px rgba(0,0,0,0.8); }
    .sugg-item { padding: 12px 20px; cursor: pointer; border-bottom: 1px solid #27272a; color: white; }
    .sugg-item:hover { background: #27272a; color: #e12afb; }
    .admin-table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
    .admin-table th { text-align: left; padding: 16px 24px; color: #71717b; font-size: 12px; font-weight: 800; text-transform: uppercase; border-bottom: 1px solid #27272a; }
    .admin-table td { padding: 20px 24px; border-bottom: 1px solid #27272a; font-size: 14px; vertical-align: middle; }
    .user-cell { display: flex; align-items: center; gap: 12px; }
    .user-cell img { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #3f3f46; }
    .badge { padding: 6px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; letter-spacing: 0.5px; }
    .badge-admin { background: rgba(225,42,251,0.1); color: #e12afb; border: 1px solid rgba(225,42,251,0.2); }
    .badge-user { background: rgba(63,63,71,0.3); color: #a1a1aa; border: 1px solid rgba(63,63,71,0.5); }
    .badge-warning { background: rgba(254,154,0,0.1); color: #fe9a00; font-size: 13px; }
    .status { display: flex; align-items: center; gap: 8px; font-weight: 500; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; }
    .action-btn { background: rgba(39,39,42,0.8); border: 1px solid #3f3f46; color: #a1a1aa; width: 36px; height: 36px; border-radius: 10px; cursor: pointer; transition: 0.2s; margin-left: 8px; }
    .action-btn:hover { background: #52525b; color: white; transform: scale(1.05); }
    .action-delete:hover { background: #ff2056; border-color: #ff2056; }
    .position-input { width: 44px; height: 44px; background: rgba(24,24,27,1); border: 1px solid #3f3f46; border-radius: 10px; color: #a1a1aa; font-weight: bold; text-align: center; font-size: 16px; transition: 0.2s; }
    .position-input:hover { border-color: #e12afb; color: white; }
    .position-input::-webkit-inner-spin-button { -webkit-appearance: none; }
    .artist-cell { display: flex; align-items: center; gap: 16px; }
    .artist-cell img { width: 48px; height: 48px; border-radius: 12px; object-fit: cover; }
    .artist-info { display: flex; flex-direction: column; gap: 4px; }
    .artist-desc-box { display: flex; gap: 20px; margin-top: 20px; align-items: center; padding-left: 64px; }
    .desc-text { background: rgba(9,9,11,1); border: 1px solid #3f3f46; border-radius: 14px; padding: 16px; color: #a1a1aa; font-size: 14px; flex-grow: 1; resize: none; height: 80px; outline: none; transition: 0.3s; }
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #3f3f46; transition: .4s; border-radius: 34px; }
    .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: #00bc7d; }
    input:checked + .slider:before { transform: translateX(20px); }
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 9999; }
    .modal-box { background: #18181b; border: 1px solid #3f3f46; padding: 30px; border-radius: 20px; width: 400px; text-align: left; }
    .custom-select { width: 100%; padding: 12px; background: #09090b; color: white; border: 1px solid #3f3f46; border-radius: 10px; margin-top: 15px; }
    .btn-cancel { background: transparent; color: #a1a1aa; border: none; padding: 10px 20px; cursor: pointer; font-weight: bold; }
    .btn-confirm { background: linear-gradient(135deg, #d946ef, #8b5cf6); color: white; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer; font-weight: bold; }
</style>
{% endblock %}
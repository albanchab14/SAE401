{% extends "layout.njk" %}

{% block content %}
<div class="page-content">
    
<div class="artist-header" style="position: relative; margin-bottom: 60px; min-height: 380px; display: flex; align-items: flex-end; border-radius: 40px; overflow: hidden; background: #09090b;">
    
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 0;">
        <img src="{{ artist.image }}" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.25) saturate(1.2);">
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(0deg, rgba(9,9,11,1) 0%, rgba(9,9,11,0.4) 100%);"></div>
    </div>

    <div style="position: relative; z-index: 1; display: flex; align-items: flex-end; gap: 40px; padding: 40px; width: 100%;">
        
        <div style="width: 240px; height: 240px; border-radius: 28px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.6); flex-shrink: 0; border: 1px solid rgba(255,255,255,0.1);">
            <img src="{{ artist.image }}" alt="{{ artist.name }}" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        
        <div style="padding-bottom: 10px;">
            <h1 style="font-size: 72px; font-weight: 800; line-height: 1; margin-bottom: 15px; color: #f4f4f5; letter-spacing: -2px;">{{ artist.name }}</h1>
            
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 25px;">
                <span style="display: flex; align-items: center; gap: 8px; color: #a1a1aa; font-weight: 600; font-size: 15px;">
                    <i data-lucide="users" style="width:18px; color: #e12afb;"></i> {{ artist.listeners }} auditeurs
                </span>
                <span style="color: #3f3f46;">•</span>
                <span style="display: flex; align-items: center; gap: 8px; color: #a1a1aa; font-weight: 600; font-size: 15px;">
                    <i data-lucide="music" style="width:18px; color: #e12afb;"></i> {{ artist.totalAlbums }} albums                </span>
            </div>
            <button id="share-btn" onclick="copyShareLink()" style="background: #27272a; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.3s;" onmouseover="this.style.background='#3f3f46'" onmouseout="this.style.background='#27272a'">
                <i data-lucide="share-2" id="share-icon" style="width: 18px; height: 18px;"></i>
                <span id="share-text">Partager</span>
            </button>
        </div>
    </div>
</div>


    <div style="display: flex; gap: 48px;">
        <div style="flex: 2;">
            <h2 style="margin-bottom: 24px; font-size: 1.5rem; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="layers" style="color: var(--primary);"></i> Albums Populaires
            </h2>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 48px;">
                {% for alb in artist.albums %}
                <a href="/album/{{ artist.name | urlencode }}/{{ alb.title | urlencode }}" style="text-decoration: none; color: inherit;">
                    <div style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); border-radius: 20px; padding: 20px; display: flex; gap: 20px; transition: 0.2s;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
                        <img src="{{ alb.image }}" style="width: 100px; height: 100px; border-radius: 12px; object-fit: cover;">
                        <div>
                            <h3 style="font-size: 1.1rem; margin-bottom: 4px;">{{ alb.title }}</h3>
                            <p style="color: var(--text-muted); font-size: 0.9rem;">Album</p>
                        </div>
                    </div>
                </a>
                {% endfor %}
            </div>

            <h2 style="margin-bottom: 24px; font-size: 1.5rem; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="play-circle" style="color: var(--primary);"></i> Titres Phares
            </h2>
            <div style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); border-radius: 24px; overflow: hidden;">
                {% for track in artist.topTracks %}
                <div style="display: flex; align-items: center; padding: 16px 24px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <span style="width: 30px; color: var(--text-muted); font-weight: bold;">{{ track.rank }}</span>
                    <a href="/details/{{ track.title | urlencode }}" style="flex: 1; color: white; text-decoration: none; font-weight: 600;">{{ track.title }}</a>
                    <div style="text-align: right;">
                        <span style="color: var(--primary);">{{ track.listeners }}</span>
                        <p style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Auditeurs</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <div style="flex: 1;">
            
            <div style="background: #0c0c0e; border: 1px solid #1a1a1c; border-radius: 20px; padding: 24px; margin-bottom: 24px;">
                <p style="font-size: 12px; color: #a1a1aa; font-weight: 800; margin-bottom: 20px; text-transform: uppercase;">
                    Distribution des notes {% if ratingStats.total > 0 %}(Moyenne : {{ ratingStats.avg }} ⭐){% endif %}
                </p>
                {% set stats = [
                    {stars: 5, width: ratingStats.pct['5'], count: ratingStats.counts['5']},
                    {stars: 4, width: ratingStats.pct['4'], count: ratingStats.counts['4']},
                    {stars: 3, width: ratingStats.pct['3'], count: ratingStats.counts['3']},
                    {stars: 2, width: ratingStats.pct['2'], count: ratingStats.counts['2']},
                    {stars: 1, width: ratingStats.pct['1'], count: ratingStats.counts['1']}
                ] %}

                {% for row in stats %}
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                    <div style="display: flex; gap: 2px;">
                        {% for s in range(5) %}<i data-lucide="star" style="width:10px; fill: {% if s < row.stars %}#f0b100{% else %}none{% endif %}; color: #f0b100;"></i>{% endfor %}
                    </div>
                    <div style="flex: 1; height: 4px; background: #1a1a1c; border-radius: 10px; overflow: hidden;">
                        <div style="width: {{ row.width }}%; height: 100%; background: #f0b100; border-radius: 10px; transition: width 0.5s ease-in-out;"></div>
                    </div>
                    <span style="color: #a1a1aa; font-size: 12px; width: 15px; text-align: right;">{{ row.count }}</span>
                </div>
                {% endfor %}
            </div>

            <div style="background: rgba(24,24,27,0.4); border: 1px solid var(--border); border-radius: 24px; padding: 30px; position: sticky; top: 100px;">
                <h3 style="margin-bottom: 20px;"><i data-lucide="book-open" style="width: 18px;"></i> Biographie</h3>
                <div style="color: var(--text-muted); line-height: 1.6; font-size: 14px; margin-bottom: 30px;">
                    {{ artist.bio | safe }}
                </div>

                <h3 style="margin-bottom: 15px;">Tags</h3>
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    {% for tag in artist.tags %}
                    <span style="background: #27272a; padding: 6px 12px; border-radius: 8px; font-size: 11px;">{{ tag.name }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    function copyShareLink() {
        navigator.clipboard.writeText(window.location.href).then(() => {
            const btn = document.getElementById('share-btn');
            const text = document.getElementById('share-text');
            const icon = document.getElementById('share-icon');

            btn.style.background = "#22c55e"; 
            text.innerText = "Copié !";
            icon.setAttribute('data-lucide', 'check'); 
            lucide.createIcons();

            setTimeout(() => {
                btn.style.background = "#27272a"; 
                text.innerText = "Partager";
                icon.setAttribute('data-lucide', 'share-2'); 
                lucide.createIcons();
            }, 2000);
            
        }).catch(err => {
            alert("Impossible de copier le lien.");
        });
    }
</script>

{% include "comments.njk" %}

{% endblock %}